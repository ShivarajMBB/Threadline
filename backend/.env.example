# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/threadline-crm
# For production, use MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/threadline-crm

# JWT Secret (generate a strong random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Facebook/Instagram App Credentials
# Get these from https://developers.facebook.com
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# Webhook Verification Token (can be any string you choose)
WEBHOOK_VERIFY_TOKEN=threadline_verify_token_2026

# Client URL (frontend)
CLIENT_URL=http://localhost:3000
# For production:
# CLIENT_URL=https://app.threadlinecrm.com

# Stripe (for sales pages - optional)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key

# Optional: Email service (for notifications)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password

# Optional: Cloud storage (for image uploads)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=threadline-uploads
AWS_REGION=us-east-1
